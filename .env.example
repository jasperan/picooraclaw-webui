# Oracle Free system password (used by picooraclaw-oracle)
ORACLE_PWD=oracle

# Host port to expose Oracle on (default 1521)
ORACLE_PORT=1521

# Host port to expose the webui on (default 3000)
WEBUI_PORT=3000

# Optional: override the picooraclaw image tag
# PICOORACLAW_IMAGE=ghcr.io/jasperan/picooraclaw:latest
